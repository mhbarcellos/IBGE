    "import:discover": "node scripts/importers/discoverPdfLinks.mjs",
    "import:infer": "node scripts/importers/inferDiscoveredFiles.mjs",
    "import:download": "node scripts/importers/downloadExamFiles.mjs",
    "import:extract": "node scripts/importers/extractTextFromPdfs.mjs",
    "import:check": "node scripts/importers/checkPdfPipeline.mjs",
    "import:archive-irrelevant": "node scripts/importers/archiveIrrelevantDiscoveredFiles.mjs",
    "import:clean-discovered": "node scripts/importers/reclassifyAndArchiveDiscoveredFiles.mjs",
    "import:pdfs": "npm run import:discover && npm run import:infer && npm run import:download && npm run import:extract && npm run import:check",
    "reset:imports": "node scripts/maintenance/resetImportedContent.mjs",
    "pci:clean-bad": "node scripts/importers/pci/cleanBadPciImports.mjs",
    "pci:discover": "node scripts/importers/pci/discoverPciIbgeExams.mjs",
    "pci:pdf-links": "node scripts/importers/pci/importPciPdfLinks.mjs",
    "pci:download-pdfs": "node scripts/importers/pci/downloadPciPdfs.mjs",
    "pci:extract-text": "node scripts/importers/pci/extractPciPdfText.mjs",
    "pci:parse-pdfs": "node scripts/importers/pci/parsePciQuestionsFromPdfs.mjs",
    "pci:questions": "node scripts/importers/pci/importPciIbgeQuestions.mjs",
    "pci:check": "node scripts/importers/pci/checkPciImport.mjs",
    "pci:pdf-import": "npm run pci:pdf-links && npm run pci:download-pdfs && npm run pci:extract-text && npm run pci:parse-pdfs && npm run pci:check",
    "pci:import": "npm run pci:discover && npm run pci:pdf-import",
    "manual:pdf-pair": "node scripts/importers/manual/importManualPdfPair.mjs",
    "manual:download-pdfs": "node scripts/importers/manual/downloadManualPdfs.mjs",
    "manual:extract-text": "node scripts/importers/manual/extractManualPdfText.mjs",
    "manual:parse-pdfs": "node scripts/importers/manual/parseManualPdfQuestions.mjs",
    "manual:import": "npm run manual:pdf-pair && npm run manual:download-pdfs && npm run manual:extract-text && npm run manual:parse-pdfs && npm run pci:check",
    "ibge:discover": "node scripts/importers/ibge/discoverPublicIbgeSources.mjs",
    "ibge:import-all": "node scripts/importers/ibge/importAllIbgeExams.mjs",
    "ibge:check": "node scripts/importers/ibge/checkIbgeImport.mjs",
    "ibge:clean-auto": "node scripts/importers/ibge/cleanAutoImportArtifacts.mjs",
    "ibge:clean-irrelevant-files": "node scripts/importers/ibge/cleanIrrelevantExamFiles.mjs"
