{
  "name": "ibge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "seed:sources": "node scripts/seedSources.mjs",
    "seed:exams": "node scripts/seedExams.mjs",
    "seed:materials": "node scripts/seedMaterials.mjs",
    "check:supabase": "node scripts/checkSupabase.mjs",
    "questions:classify": "node scripts/classification/classifyImportedQuestions.mjs",
    "questions:classify-role": "node scripts/classification/classifyTargetRoleFocus.mjs",
